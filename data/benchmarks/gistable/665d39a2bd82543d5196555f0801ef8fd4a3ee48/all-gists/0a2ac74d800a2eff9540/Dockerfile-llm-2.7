# FROM is the found expected Python version
FROM python:2.7
# Set the working directory to /app
WORKDIR /app
# Add install commands for all of the python modules
RUN ["pip","install","--upgrade","pip"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","appindicator==1.13.0"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","gtk==4.0.3"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","urllib2==1.26.19"]
# Copy the specified directory to /app
COPY snippet.py /app
# Run the specified python file
CMD ["python", "/app/snippet.py"]