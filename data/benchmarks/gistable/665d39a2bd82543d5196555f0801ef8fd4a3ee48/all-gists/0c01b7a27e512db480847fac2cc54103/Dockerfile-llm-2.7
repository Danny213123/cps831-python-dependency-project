# FROM is the found expected Python version
FROM python:2.7
# Set the working directory to /app
WORKDIR /app
# Add install commands for all of the python modules
RUN ["pip","install","--upgrade","pip"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","objc_util==5.1.0"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","cfurl==2.1.1"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","nsuserdefaults==recent"]
# Copy the specified directory to /app
COPY snippet.py /app
# Run the specified python file
CMD ["python", "/app/snippet.py"]