# FROM is the found expected Python version
FROM python:2.7
# Set the working directory to /app
WORKDIR /app
# Add install commands for all of the python modules
RUN ["pip","install","--upgrade","pip"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","win32api==10.0.30306"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","win32security==10.0.19041.3639"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","_winreg==3.0.7"]
# Copy the specified directory to /app
COPY snippet.py /app
# Run the specified python file
CMD ["python", "/app/snippet.py"]